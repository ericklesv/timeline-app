# ──────────────────────────────────────────────────
#  Timeline App — Environment Variables
#  Copy this file to .env.local for local development
# ──────────────────────────────────────────────────

# ----- Data storage --------------------------------
# Directory where events.json, settings.json and notifications.json are stored.
# Leave empty to use <project_root>/data (default for local dev).
# On Railway: attach a Volume at /data and set DATA_DIR=/data
DATA_DIR=

# ----- Cron protection (optional) ------------------
# If set, GET/POST /api/telegram/cron requires:
#   header:  Authorization: Bearer <CRON_SECRET>
#   OR query: ?secret=<CRON_SECRET>
# Leave empty to allow unauthenticated calls (fine for localhost).
CRON_SECRET=
